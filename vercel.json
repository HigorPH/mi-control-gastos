{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/diario",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/mensual",
      "schedule": "0 10 1 * *"
    }
  ]
}
